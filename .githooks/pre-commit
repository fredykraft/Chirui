#!/usr/bin/env bash
# Pre-commit hook to prevent accidentally committing sensitive files
# 
# Installation:
#   1. Save this file to: .git/hooks/pre-commit
#   2. Make it executable: chmod +x .git/hooks/pre-commit
#
# This will automatically run when you try to commit, and will prevent
# committing any files matching the sensitive file patterns.

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "🔒 Running pre-commit security checks..."

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only)

# Flag for whether we found any issues
ISSUES_FOUND=0

# Check for sensitive files being committed
echo ""
echo "Checking for sensitive files..."

SENSITIVE_PATTERNS=(
    "\.env$"
    "\.env\.local"
    "\.env\..*\.local"
    "ADMIN_PASSWORD\.md"
    "\.secret"
    "\.pem$"
    "\.key$"
    "\.p8$"
    "\.p12$"
    "credentials"
    "secret"
)

for file in $STAGED_FILES; do
    for pattern in "${SENSITIVE_PATTERNS[@]}"; do
        if [[ $file =~ $pattern ]]; then
            echo -e "${RED}✗ BLOCKED:${NC} Sensitive file detected: $file"
            ISSUES_FOUND=1
        fi
    done
done

# Check for hardcoded secrets in staged content
echo ""
echo "Checking staged content for hardcoded secrets..."

SECRETS_FOUND=0

# Check for common secret patterns
if git diff --cached | grep -iE "passwd|password|api[_-]?key|secret|token|auth|credential" > /dev/null 2>&1; then
    echo -e "${YELLOW}⚠️  WARNING:${NC} Staged changes may contain secrets or passwords"
    echo "   Review the following matches:"
    git diff --cached | grep -iEn "passwd|password|api[_-]?key|secret|token|auth|credential" | head -10
    echo ""
    read -p "Continue anyway? (y/n) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        ISSUES_FOUND=1
    fi
fi

# Check for hardcoded URLs (localhost)
echo ""
echo "Checking for hardcoded development URLs..."

if git diff --cached | grep -E "127\.0\.0\.1:8090|localhost:8090" > /dev/null 2>&1; then
    echo -e "${RED}✗ BLOCKED:${NC} Hardcoded localhost development URL detected"
    git diff --cached | grep -nE "127\.0\.0\.1:8090|localhost:8090"
    ISSUES_FOUND=1
fi

# Summary
echo ""
if [ $ISSUES_FOUND -eq 0 ]; then
    echo -e "${GREEN}✓ All pre-commit security checks passed${NC}"
    echo "  Proceeding with commit..."
else
    echo -e "${RED}✗ Pre-commit checks failed${NC}"
    echo ""
    echo "⚠️  ABORT: Your commit contains issues that must be fixed"
    echo ""
    echo "To fix:"
    echo "1. Review .gitignore for sensitive file patterns"
    echo "2. Remove sensitive files: git reset <file>"
    echo "3. Update .env or secrets files outside version control"
    echo ""
    exit 1
fi

exit 0
