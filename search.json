---
layout: null
---
[
  {% assign searchable_pages = site.html_pages | where_exp: "item", "item.url != '/404.html'" %}
  {% assign searchable_posts = site.posts %}

  {% for page in searchable_pages %}
    {
      "title"    : "{{ page.title | default: page.url | escape }}",
      "category" : "Page",
      "tags"     : "",
      "url"      : "{{ site.baseurl }}{{ page.url }}",
      "date"     : "",
      "content"  : "{{ page.content | strip_html | normalize_whitespace | escape }}"
    } {% unless forloop.last and searchable_posts.size == 0 %},{% endunless %}
  {% endfor %}

  {% for post in searchable_posts %}
    {
      "title"    : "{{ post.title | escape }}",
      "category" : "{{ post.category }}",
      "tags"     : "{{ post.tags | array_to_sentence_string }}",
      "url"      : "{{ site.baseurl }}{{ post.url }}",
      "date"     : "{{ post.date }}",
      "content"  : "{{ post.content | strip_html | normalize_whitespace | escape }}"
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
